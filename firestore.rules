rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email in ['ursa2706@gmail.com', 'karlo.casni2@gmail.com', 'brunovujcec6@gmail.com'] ||
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('isAdmin', false) == true
      );
    }

    match /profiles/{userId} {
      // Any authenticated user can read profiles
      allow read: if request.auth != null;
      
      // Only the profile owner can create, but cannot set protected fields
      allow create: if request.auth != null && request.auth.uid == userId && 
        (!request.resource.data.keys().hasAny(['isAdmin', 'status', 'offsetDays']) || 
         (request.resource.data.get('isAdmin', false) == false && 
          request.resource.data.get('status', 'inactive') == 'inactive' && 
          request.resource.data.get('offsetDays', 0) == 0));
      
      // Allow incrementing xp and level by others.
      // Owner can update their profile but cannot change protected fields.
      // Admins have full access.
      allow update: if request.auth != null && (
        isAdmin() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['xp', 'level'])) ||
        (request.auth.uid == userId && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'status', 'offsetDays'])))
      );
      
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && (request.resource.data.authorId == request.auth.uid || isAdmin());
      
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.authorId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentsCount']) ||
        isAdmin()
      );
      allow delete: if request.auth != null && (request.auth.uid == resource.data.authorId || isAdmin());

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && (request.resource.data.authorId == request.auth.uid || isAdmin());
        allow update, delete: if request.auth != null && (request.auth.uid == resource.data.authorId || isAdmin());
      }
    }

    match /chats/{chatId} {
      // Allow reading/writing if the user is a participant
      allow read, write: if request.auth != null && (request.auth.uid in resource.data.participants || isAdmin());
      // Allow creating if the user is one of the participants
      allow create: if request.auth != null && (request.auth.uid in request.resource.data.participants || isAdmin());
      // Allow updating if the user is a participant
      allow update: if request.auth != null && (request.auth.uid in resource.data.participants || isAdmin());

      match /messages/{messageId} {
        allow read: if request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
        allow create: if request.auth != null && (request.auth.uid == request.resource.data.senderId || isAdmin());
      }
    }

    match /notifications/{notifId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.recipientId || isAdmin());
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid == resource.data.recipientId || isAdmin());
      allow delete: if isAdmin();
    }

    match /challenges/{challengeId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();

      match /submissions/{submissionId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
        allow update: if isAdmin();
        allow delete: if isAdmin() || request.auth.uid == resource.data.authorId;
      }
    }

    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Global settings or other collections
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
